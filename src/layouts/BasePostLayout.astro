---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;

const { title, description, date, publishDate, tags } = frontmatter || Astro.props;
const createdTime = date ? new Date(date).toISOString() : undefined;
const publishedTime = publishDate ? new Date(publishDate).toISOString() : undefined;
const shouldShowBothDates = Boolean(
    date &&
    publishDate &&
    new Date(date).getTime() !== new Date(publishDate).getTime(),
);
const postUrl = new URL(Astro.url.pathname, Astro.site).toString();
const articleSchema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    description,
    url: postUrl,
    datePublished: publishedTime,
    dateCreated: createdTime,
    dateModified: publishedTime,
    author: {
        "@type": "Person",
        name: "Luiz Gustavo",
        url: Astro.site?.toString(),
    },
    publisher: {
        "@type": "Person",
        name: "Luiz Gustavo",
        url: Astro.site?.toString(),
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": postUrl,
    },
    keywords: tags,
    inLanguage: "pt-BR",
};
---

<BaseLayout
    title={title}
    description={description}
    ogType="article"
    publishedTime={publishedTime}
    keywords={tags}
>
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <header class="mb-5 sm:mb-10">
        <h1
            class="text-2xl sm:text-3xl font-bold text-[#586e75] dark:text-[#eee8d5]"
        >
            {title}
        </h1>

        <div class="mt-1.5 sm:mt-3 text-xs sm:text-sm">
            <div class="flex items-center gap-1.5 text-[#93a1a1] dark:text-[#586e75] flex-wrap">
                {publishDate && !shouldShowBothDates && (
                    <>
                        <time datetime={new Date(publishDate).toISOString()} class="italic">
                            {new Date(publishDate).toLocaleDateString("pt-BR", {
                                day: "2-digit",
                                month: "short",
                                year: "numeric",
                            })}
                        </time>
                    </>
                )}

                {publishDate && shouldShowBothDates && (
                    <>
                        <span>publicado:</span>
                        <time datetime={new Date(publishDate).toISOString()} class="italic">
                            {new Date(publishDate).toLocaleDateString("pt-BR", {
                                day: "2-digit",
                                month: "short",
                                year: "numeric",
                            })}
                        </time>
                    </>
                )}

                {date && shouldShowBothDates && (
                    <>
                        <span class="text-[#6c71c4] dark:text-[#6c71c4]">|</span>
                        <span>criado:</span>
                        <time datetime={new Date(date).toISOString()} class="italic">
                            {new Date(date).toLocaleDateString("pt-BR", {
                                day: "2-digit",
                                month: "short",
                                year: "numeric",
                            })}
                        </time>
                    </>
                )}
            </div>

            {tags && tags.length > 0 && (
                <div class="mt-1 flex gap-2 flex-wrap">
                    {tags.map((tag: string) => (
                        <a
                            href={`/tags/${tag}`}
                            class="
                                text-[#d33682] dark:text-[#d33682]
                                hover:text-[#268bd2] dark:hover:text-[#268bd2]
                                hover:underline decoration-1 underline-offset-2
                            "
                        >
                            #{tag}
                        </a>
                    ))}
                </div>
            )}
        </div>
    </header>

    <slot />
</BaseLayout>
