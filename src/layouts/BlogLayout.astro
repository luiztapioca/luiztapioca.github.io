---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
})).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog" description="Minhas resenhas e pensamentos">
    <section>
        <div class="mb-8 text-[#657b83] dark:text-[#93a1a1]">
            <slot />
        </div>

        <div class="not-prose flex flex-col gap-3 text-xs sm:text-sm font-monaco">
            {posts.map((post) => (
                <a
                    href={`/blog/${post.id}/`}
                    class="group flex flex-col gap-0.5 [text-decoration:none] hover:[text-decoration:none]"
                >
                    <div class="flex items-baseline gap-1.5 min-w-0">
                        <span class="text-[#d33682] shrink-0">✦</span>
                        <span class="
                            truncate
                            text-[#657b83] dark:text-[#93a1a1]
                            group-hover:text-[#d33682] dark:group-hover:text-[#d33682]
                        ">
                            {post.data.title}
                        </span>
                        {post.data.draft && (
                            <span class="text-[#cb4b16] shrink-0">[rascunho]</span>
                        )}
                        <span class="flex-1 border-b border-dotted border-[#93a1a1]/40 dark:border-[#586e75]/40 translate-y-[-0.3em] mx-1"></span>
                        <time
                            datetime={post.data.date.toISOString()}
                            class="text-[#93a1a1] dark:text-[#586e75] whitespace-nowrap shrink-0"
                        >
                            {post.data.date.toLocaleDateString('pt-BR', {
                                day: '2-digit',
                                month: 'short',
                                year: 'numeric',
                            })}
                        </time>
                    </div>
                    {post.data.tags && (
                        <div class="flex gap-2 pl-4 text-[0.85em] text-[#93a1a1] dark:text-[#586e75]">
                            {post.data.tags.map((tag) => (
                                <span class="group-hover:text-[#268bd2]">#{tag}</span>
                            ))}
                        </div>
                    )}
                </a>
            ))}
        </div>
    </section>
</BaseLayout>
