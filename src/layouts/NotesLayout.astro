---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const notes = (await getCollection("notes", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
})).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Notas" description="Notas e anotações rápidas">
    <section>
        <div class="mb-8 text-[#657b83] dark:text-[#93a1a1]">
            <slot />
        </div>

        {notes.length === 0 ? (
            <div class="not-prose text-center py-12 text-[#93a1a1] dark:text-[#586e75]">
                <span class="text-2xl block mb-2">(´・ω・`)</span>
                <span class="text-sm">nenhuma nota ainda...</span>
            </div>
        ) : (
        <div class="not-prose flex flex-col gap-3 text-xs sm:text-sm font-maple">
            {notes.map((post) => (
                <a
                    href={`/notes/${post.id}/`}
                    class="group flex items-baseline gap-2 min-w-0 [text-decoration:none] hover:[text-decoration:none]"
                >
                    <span class="text-[#d33682] dark:text-[#d33682] shrink-0">✦</span>
                    <span class="
                        truncate
                        text-[#657b83] dark:text-[#93a1a1]
                        group-hover:text-[#d33682] dark:group-hover:text-[#d33682]
                    ">
                        {post.data.title}
                    </span>
                    {post.data.draft && (
                        <span class="text-[#cb4b16] dark:text-[#cb4b16] shrink-0">[rascunho]</span>
                    )}
                    <span class="flex-1 min-w-4 h-px translate-y-[-0.3em] bg-[radial-gradient(circle,_#93a1a140_1.5px,_transparent_1.5px)] dark:bg-[radial-gradient(circle,_#586e7540_1.5px,_transparent_1.5px)] bg-[length:8px_3px]"></span>
                    <time
                        datetime={post.data.date.toISOString()}
                        class="text-[#93a1a1] dark:text-[#586e75] whitespace-nowrap shrink-0"
                    >
                        {post.data.date.toLocaleDateString('pt-BR', {
                            day: '2-digit',
                            month: 'short',
                            year: 'numeric',
                        })}
                    </time>
                </a>
            ))}
        </div>
        )}
    </section>
</BaseLayout>
