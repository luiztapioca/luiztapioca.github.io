---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const allPosts = await getCollection("posts", ({ data }) => {
        return import.meta.env.PROD ? data.draft !== true : true;
    });

    const uniqueTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];

    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts
            .filter((post) => post.data.tags?.includes(tag))
            .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout title={`Tag: #${tag}`} description={`Posts marcados com ${tag}`}>
    <section class="mt-4 sm:mt-8">
        <h1 class="not-prose text-sm sm:text-lg font-bold font-monaco text-[#586e75] dark:text-[#eee8d5] mb-6">
            <span class="text-[#268bd2]"># </span>{tag}
        </h1>

        <div class="not-prose flex flex-col gap-3 text-xs sm:text-sm font-monaco">
            {posts.map((post) => (
                <a
                    href={`/blog/${post.id}/`}
                    class="group flex items-baseline gap-1.5 min-w-0 [text-decoration:none] hover:[text-decoration:none]"
                >
                    <span class="text-[#d33682] shrink-0">✦</span>
                    <span class="
                        truncate
                        text-[#657b83] dark:text-[#93a1a1]
                        group-hover:text-[#d33682] dark:group-hover:text-[#d33682]
                    ">
                        {post.data.title}
                    </span>
                    <span class="flex-1 border-b border-dotted border-[#93a1a1]/40 dark:border-[#586e75]/40 translate-y-[-0.3em] mx-1"></span>
                    <time
                        datetime={post.data.date.toISOString()}
                        class="text-[#93a1a1] dark:text-[#586e75] whitespace-nowrap shrink-0"
                    >
                        {post.data.date.toLocaleDateString('pt-BR', {
                            day: '2-digit',
                            month: 'short',
                            year: 'numeric',
                        })}
                    </time>
                </a>
            ))}
        </div>
    </section>
</BaseLayout>
