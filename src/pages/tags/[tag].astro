---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const allPosts = await getCollection("posts", ({ data }) => {
        return import.meta.env.PROD ? data.draft !== true : true;
    });

    const uniqueTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];

    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts
            .filter((post) => post.data.tags?.includes(tag))
            .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout title={`Tag: #${tag}`} description={`Posts marcados com ${tag}`}>
    <section class="mt-4 sm:mt-8">
        <h2 class="not-prose text-lg sm:text-xl mb-6 text-[#657b83] dark:text-[#93a1a1]">
            <span class="text-[#d33682] dark:text-[#d33682]"></span> # {tag}
        </h2>

        {posts.length === 0 ? (
            <div class="not-prose text-center py-12 text-[#93a1a1] dark:text-[#586e75]">
                <span class="text-2xl block mb-2">(；・∀・)</span>
                <span class="text-sm">nenhum post com essa tag...</span>
            </div>
        ) : (
        <div class="not-prose flex flex-col gap-3 text-xs sm:text-sm ">
            {posts.map((post) => (
                <a
                    href={`/${post.id}/`}
                    class="group flex items-baseline gap-2 min-w-0 [text-decoration:none] hover:[text-decoration:none]"
                >
                    <span class="text-[#d33682] dark:text-[#d33682] shrink-0">></span>
                    <span class="
                        truncate
                        text-[#657b83] dark:text-[#93a1a1]
                        group-hover:text-[#d33682] dark:group-hover:text-[#d33682]
                    ">
                        {post.data.title}
                    </span>
                    <span class="flex-1 min-w-4 h-px translate-y-[-0.3em] bg-[radial-gradient(circle,_#93a1a140_1.5px,_transparent_1.5px)] dark:bg-[radial-gradient(circle,_#586e7540_1.5px,_transparent_1.5px)] bg-[length:8px_3px]"></span>
                    <time
                        datetime={post.data.date.toISOString()}
                        class="text-[#93a1a1] dark:text-[#586e75] whitespace-nowrap shrink-0"
                    >
                        {post.data.date.toLocaleDateString('pt-BR', {
                            day: '2-digit',
                            month: 'short',
                            year: 'numeric',
                        })}
                    </time>
                </a>
            ))}
        </div>
        )}
    </section>
</BaseLayout>
