---
const cvCacheBust =
  process.env.GITHUB_SHA?.slice(0, 8) ??
  process.env.GITHUB_RUN_ID ??
  String(Date.now());

const cvHref = `/cv.pdf?v=${cvCacheBust}`;
const cvPtBrHref = `/cv-pt-br.pdf?v=${cvCacheBust}`;
---

<footer class="my-2 sm:my-4 select-none">
    <div class="flex items-center gap-3 mb-3">
        <span
            class="flex-1 border-t sm:border-t-2 border-dashed border-[#93a1a1] dark:border-[#586e75]"
        ></span>
    </div>
    <div class="flex items-center justify-between gap-4 mb-3 text-xs sm:text-sm">
        <div class="text-[#657b83] dark:text-[#93a1a1] font-medium">
            {new Date().getFullYear()}
        </div>

        <div class="flex items-center gap-3 text-[#657b83] dark:text-[#839496]">
            <a
                href={cvHref}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-[#268bd2] dark:hover:text-[#268bd2] transition-colors"
                title="CV"
            >
                cv
            </a>
            <a
                href={cvPtBrHref}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-[#268bd2] dark:hover:text-[#268bd2] transition-colors"
                title="CV (pt-BR)"
            >
                cv (pt-br)
            </a>
            <a
                href="https://github.com/rosadehiroshima"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-[#268bd2] dark:hover:text-[#268bd2] transition-colors"
                title="GitHub"
            >
                github
            </a>
            <a
                href="/rss.xml"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-[#268bd2] dark:hover:text-[#268bd2] transition-colors"
                title="RSS Feed"
            >
                rss
            </a>
        </div>
    </div>
</footer>
