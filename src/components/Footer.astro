---
import { Rss } from "@lucide/astro";
---

<footer class="my-2 sm:my-4 select-none">
    <div class="flex items-center gap-3 mb-3">
        <span
            class="flex-1 border-t sm:border-t-2 border-dashed border-[#93a1a1] dark:border-[#586e75]"
        ></span>
    </div>
    <div class="flex items-center gap-4 mb-3">
        <!-- Left: Site Name and Year Range -->
        <div class="flex-1 text-sm text-[#d33682] dark:text-[#d33682]">
            rosa de hiroshima © 2024-{new Date().getFullYear()}
        </div>

        <!-- Right: RSS Feed -->
        <a
            href="/rss.xml"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#657b83] dark:text-[#839496] hover:text-[#268bd2] dark:hover:text-[#268bd2] transition-colors flex items-center gap-1 flex-shrink-0"
            title="RSS Feed"
        >
            <Rss size={20} />
            <span class="text-xs sm:text-sm">rss</span>
        </a>
    </div>
</footer>
